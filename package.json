{
    "name": "@yourorg/design-tokens",
    "version": "1.0.0",
    "description": "Framework-agnostic token-based design system",
    "main": "dist/index.js",
    "types": "dist/index.d.ts",
    "files": [
        "dist/",
        "css/",
        "tokens/"
    ],
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "require": "./dist/index.cjs"
        },
        "./css": "./css/foundations.css",
        "./css/themes": "./css/themes.css",
        "./css/utilities": "./css/utilities.css",
        "./tokens": "./tokens/tokens.json",
        "./tokens/*": "./tokens/*.json"
    },
    "scripts": {
        "build": "npm run build:themes && npm run build:tokens && npm run build:css && npm run build:js",
        "build:themes": "node scripts/generate-balanced-themes.js",
        "build:tokens": "node scripts/build-tokens.js",
        "build:css": "node scripts/build-css.js",
        "build:js": "rollup -c",
        "dev": "npm run build -- --watch",
        "test": "jest",
        "lint": "eslint ."
    },
    "keywords": [
        "design-system",
        "design-tokens",
        "css-variables",
        "theming",
        "framework-agnostic"
    ],
    "author": "Your Name",
    "license": "MIT",
    "devDependencies": {
        "@rollup/plugin-typescript": "^11.1.5",
        "jest": "^29.7.0",
        "rollup": "^4.9.6",
        "typescript": "^5.3.3"
    },
    "peerDependencies": {},
    "repository": {
        "type": "git",
        "url": "https://github.com/yourorg/design-tokens"
    }
}